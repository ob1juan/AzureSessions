{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "virtualMachineName": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "customLocationName": {
      "type": "string"
    },
    "vCenterName": {
      "type": "string"
    },
    "networkName": {
      "type": "string"
    },
    "nicType": {
      "type": "string",
      "defaultValue": "e1000e"
    },
    "templateName": {
      "type": "string"
    },
    "clusterName": {
      "type": "string"
    },
    "adminUserName" : {
      "type": "string"
    },
    "passwordLength": {
      "type": "int",
      "defaultValue": 16,
      "metadata": {
        "description": "Length of the auto-generated admin password."
      }
    },
    "adminPasswordSecretName": {
      "type": "string",
      "defaultValue": "adminPassword",
      "metadata": {
        "description": "The name of the Key Vault secret that stores the generated admin password."
      }
    }
  },
  "variables": {
    "extendedLocation": "[concat('/subscriptions/', subscription().subscriptionId,'/resourcegroups/',resourceGroup().name, '/providers/microsoft.extendedlocation/customlocations/', parameters('customLocationName') )]",
    "vCenterId": "[concat('/subscriptions/', subscription().subscriptionId,'/resourcegroups/',resourceGroup().name, '/providers/Microsoft.ConnectedVMwarevSphere/VCenters/', parameters('vCenterName') )]",
    "networkId": "[concat('/subscriptions/', subscription().subscriptionId,'/resourcegroups/',resourceGroup().name, '/providers/Microsoft.ConnectedVMwarevSphere/VirtualNetworks/', parameters('networkName') )]",
    "templateId": "[concat('/subscriptions/', subscription().subscriptionId,'/resourcegroups/',resourceGroup().name, '/providers/Microsoft.ConnectedVMwarevSphere/VirtualMachineTemplates/', parameters('templateName') )]",
    "clusterId": "[concat('/subscriptions/', subscription().subscriptionId,'/resourcegroups/',resourceGroup().name, '/providers/Microsoft.ConnectedVMwarevSphere/Clusters/', parameters('clusterName') )]",
    "keyVaultName": "[toLower(concat('kv-vsphere-', substring(uniqueString(resourceGroup().id), 0, 6)))]",
    "randomSeed": "[uniqueString(resourceGroup().id, deployment().name)]",
    "generatedAdminPassword": "[concat('Aa1!', substring(base64(variables('randomSeed')), 0, sub(parameters('passwordLength'), 4)))]"
  },
  "resources": [
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "family": "A", "name": "standard" },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 7
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), parameters('adminPasswordSecretName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ],
      "properties": {
        "value": "[variables('generatedAdminPassword')]"
      }
    },
    {
      "type": "Microsoft.ConnectedVMwarevSphere/virtualMachines",
      "apiVersion": "2020-10-01-preview",
      "name": "[parameters('virtualMachineName')]",
      "location": "[parameters('location')]",
      "kind": "VMware",
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), parameters('adminPasswordSecretName'))]"
      ],
      "extendedLocation": {
        "name": "[variables('extendedLocation')]",
        "type": "CustomLocation"
      },
      "identity" : {
        "type" : "SystemAssigned"
      },
      "properties": {
        "vCenterId": "[variables('vCenterId')]",
        "templateId": "[variables('templateId')]",
        "placementProfile": {
          "clusterId": "[variables('clusterId')]"
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "name": "NIC01",
              "networkId": "[variables('networkId')]",
              "nicType": "[parameters('nicType')]",
              "powerOnBoot": "enabled",
              "ipSettings": {
                "allocationMethod": "dynamic"
              }
            }
          ]
        },
        "hardwareProfile": {
          "memorySizeMB": 4096,
          "numCPUs": 2,
          "numCoresPerSocket": 1
        },
        "osProfile": {
          "osType": "Windows",
          "computerName": "[parameters('virtualMachineName')]",
          "adminPassword" : "[variables('generatedAdminPassword')]"
        }
      }
    },
    {
            "type": "Microsoft.ConnectedVMwarevSphere/VirtualMachines/guestAgents",
            "apiVersion": "2020-10-01-preview",
            "name": "[concat(parameters('virtualMachineName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.ConnectedVMwarevSphere/VirtualMachines', parameters('virtualMachineName'))]"
            ],
            "properties": {
                "credentials": {
                    "username": "[parameters('adminUserName')]",
                    "password" : "[variables('generatedAdminPassword')]"
                },
                "provisioningAction": "install"
            }
    }
  ]
}
