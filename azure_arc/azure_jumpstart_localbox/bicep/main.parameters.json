{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "tenantId": {
            "value": "<your service principal tenant id>"
        },
        "spnProviderId": {
            "value": "<your Microsoft.AzureStackHCI resource provider object id>"
        },
        "windowsAdminUsername": {
            "value": "arcdemo"
        },
        "windowsAdminPassword": {
            "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
        },
        "logAnalyticsWorkspaceName": {
            "value": "LocalBox-Workspace"
        },
        "deployBastion": {
            "value": false
        },
        "autoDeployClusterResource": {
            "value": false
        },
        "autoUpgradeClusterResource": {
            "value": false
        }
    }
}
