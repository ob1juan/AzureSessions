{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "sshRSAPublicKey": {
      "value": "<your RSA public key>"
    },
    "spnClientId": {
      "value": "<your service principal client id>"
    },
    "spnClientSecret": {
      "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
    },
    "spnTenantId": {
      "value": "<your spn tenant id>"
    },
    "windowsAdminUsername": {
      "value": "arcdemo"
    },
    "windowsAdminPassword": {
      "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
    },
    "logAnalyticsWorkspaceName": {
      "value": "<your unique Log Analytics workspace name>"
    },
    "deploySQLMI": {
      "value": "<SQL Managed Instance deployment (true/false)>"
    },
    "deployPostgreSQL": {
      "value": "<PostgreSQL deployment (true/false)>"
    },
    "templateBaseUrl": {
      "value": "https://raw.githubusercontent.com/microsoft/azure_arc/main/azure_arc_data_jumpstart/microk8s/azure/arm_template/"
    },
    "deployBastion": {
      "value": "(true/false)"
    },
    "bastionHostName": {
      "value": "<Azure Bastion Hostname>"
    }
  }
}
