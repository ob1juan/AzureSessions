{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vmSize": {
      "value": "<VM size>"
    },
    "vmName": {
      "value": "<VM Name>"
    },
    "adminUsername": {
      "value": "<Windows VM admin username>"
    },
    "adminPassword": {
      "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
    },
    "logAnalyticsWorkspaceName": {
      "value": "<your unique Log Analytics workspace name>"
    },
    "servicePrincipalAppId": {
      "value": "<Azure service principal name>"
    },
    "servicePrincipalSecret": {
      "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
    },
    "servicePrincipalTenantId": {
      "value": "<Azure tenant ID>"
    },
    "deployBastion": {
      "value": "(true/false)"
    }
  }
}
