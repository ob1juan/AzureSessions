{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "sshRSAPublicKey": {
            "value": "<your RSA public key>"
        },
        "spnClientId": {
            "value": "<your service principal client id>"
        },
        "spnClientSecret": {
            "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
        },
        "spnTenantId": {
            "value": "<your spn tenant id>"
        },
        "windowsAdminUsername": {
            "value": "arcdemo"
        },
        "windowsAdminPassword": {
            "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
        },
        "logAnalyticsWorkspaceName": {
            "value": "<your unique Log Analytics workspace name>"
        },
        "deployBastion": {
            "value": false
        },
        "bastionHostName": {
          "value": "Arc-App-Demo-Bastion"
        }
    }
}
