{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vmSize": {
      "value": "<VM size>"
    },
    "vmName": {
      "value": "<VM Name>"
    },
    "adminUsername": {
      "value": "<Windows VM admin username>"
    },
    "adminPassword": {
      "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
    },
    "resourceGroup": {
      "value": "<Azure resource group where all resource to be deployed>"
    },
    "appId": {
      "value": "<Azure service principal name>"
    },
    "password": {
      "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
    },
    "tenantId": {
      "value": "<Azure tenant ID>"
    },
    "subscriptionId": {
      "value": "<Azure subscription ID>"
    },
    "location": {
      "value": "<Azure region>"
    },
    "deployBastion": {
        "value": "<true | false>"
    },
    "bastionHostName": {
      "value": "<Azure Bastion Host name>"
    }
  }
}
