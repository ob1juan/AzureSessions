{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "clusterName": {
            "value": "<AKS cluster name>"
        },
         "linuxAdminUsername": {
            "value": "<OS Username>"
        },
        "sshRSAPublicKey": {
            "value": "<Your ssh public key>"
        },
        "servicePrincipalClientId": {
            "value": "<Your Azure service principal name>"
        },
        "servicePrincipalClientSecret": {
            "reference": {
                "keyVault": {
                    "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group-name>/providers/Microsoft.KeyVault/vaults/<key-vault-name>"
                },
                "secretName": "<secret-name>"
            }
        },
        "kubernetesVersion": {
            "value": "<Kubernetes Version, e.g. 1.31.3>"
        }
    }
}