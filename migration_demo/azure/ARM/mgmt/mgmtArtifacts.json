              },
              "natGateway": "[if(or(parameters('deployBastion'), not(equals(parameters('flavor'), 'ITPro'))), createObject('id', resourceId('Microsoft.Network/natGateways', parameters('drNatGatewayName'))), null())]",
              "defaultOutboundAccess": false
            }
          }
        ]
      },
      "dependsOn": [
        "natGatewayDR",
        "networkSecurityGroup"
      ]
    },
    "natGatewayPublicIp": {
      "condition": "[or(parameters('deployBastion'), not(equals(parameters('flavor'), 'ITPro')))]",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2024-07-01",
      "name": "[format('{0}-PIP', parameters('natGatewayName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "publicIPAllocationMethod": "Static",
