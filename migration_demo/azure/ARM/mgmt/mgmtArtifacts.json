      "sku": {
        "name": "Standard"
      }
    },
    "natGatewayDRPublicIp": {
      "condition": "[or(parameters('deployBastion'), equals(parameters('flavor'), 'DataOps'))]",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2024-07-01",
      "name": "[format('{0}-DR-PIP', parameters('natGatewayName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4",
        "idleTimeoutInMinutes": 4
      },
      "sku": {
        "name": "Standard"
      }
    },
    "natGateway": {
      "condition": "[or(parameters('deployBastion'), not(equals(parameters('flavor'), 'ITPro')))]",
      "type": "Microsoft.Network/natGateways",
      "apiVersion": "2024-07-01",
      "name": "[parameters('natGatewayName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
