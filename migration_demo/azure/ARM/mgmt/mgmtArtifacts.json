          },
          {
            "name": "allow_traefik_lb_external",
            "properties": {
              "priority": 204,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "32323"
            }
          },
          {
            "name": "allow_SQLMI_traffic",
            "properties": {
              "priority": 205,
              "protocol": "Tcp",
              "access": "Allow",
              "direction": "Inbound",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "11433"
